# MongoDB
MONGODB_URI=

# NextAuth
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# Resend
RESEND_API_KEY=
EMAIL_FROM=hello@walltrust.app

# Lemon Squeezy
LEMONSQUEEZY_API_KEY=
LEMONSQUEEZY_STORE_ID=
LEMONSQUEEZY_WEBHOOK_SECRET=
LEMONSQUEEZY_STARTER_VARIANT_ID=
LEMONSQUEEZY_PRO_VARIANT_ID=

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# e2e-only: enables e2e/security.spec.ts's rate-limit test to force real
# enforcement for one request. Only needed in local .env.local for running
# the e2e suite; never set this in production.
E2E_RATE_LIMIT_SECRET=
